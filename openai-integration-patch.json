{
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      },
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "models": {
        "anthropic/claude-sonnet-4-20250514": {
          "alias": "Claude",
          "params": {
            "cacheRetention": "short"
          }
        },
        "openai/gpt-4o": {
          "alias": "GPT-4o",
          "params": {
            "temperature": 0.7
          }
        },
        "openai/gpt-4o-mini": {
          "alias": "GPT-4o-mini", 
          "params": {
            "temperature": 0.7
          }
        },
        "openai/gpt-3.5-turbo": {
          "alias": "GPT-3.5",
          "params": {
            "temperature": 0.7
          }
        }
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "apiKey": "__OPENCLAW_REDACTED__"
      },
      "fetch": {
        "enabled": true
      }
    },
    "openai": {
      "whisper": {
        "enabled": true,
        "model": "whisper-1"
      },
      "dalle": {
        "enabled": true,
        "model": "dall-e-3",
        "size": "1024x1024",
        "quality": "standard"
      },
      "tts": {
        "enabled": true,
        "model": "tts-1",
        "voice": "alloy"
      }
    }
  }
}